/*
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: geolocation=(), microphone=(), camera=(), payment=(self), usb=(), vr=(), xr=()
  Cross-Origin-Opener-Policy: same-origin-allow-popups
  Content-Security-Policy: default-src 'self'; img-src 'self' data: https:; media-src 'self' https:; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src https://fonts.gstatic.com; script-src 'self' 'unsafe-inline'; base-uri 'self'; object-src 'none'; form-action 'self' https://buy.stripe.com; frame-ancestors 'none'; connect-src 'self' https://api.stripe.com https://buy.stripe.com

/index.html
  Cache-Control: public, max-age=3600, must-revalidate
  X-Content-Type-Options: nosniff

/*.webp
  Cache-Control: public, max-age=2592000, immutable
  
/*.mp4
  Cache-Control: public, max-age=2592000, immutable

/*.jpg
  Cache-Control: public, max-age=2592000, immutable

/og-image.jpg
  Cache-Control: public, max-age=604800

/_headers
  Cache-Control: public, max-age=3600

/sitemap.xml
  Cache-Control: public, max-age=86400
  Content-Type: application/xml
